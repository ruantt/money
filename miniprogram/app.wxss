page {
  background: #f4f7fb;
  color: #162033;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx -24rpx rgba(15, 23, 42, 0.25);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.muted {
  color: #8a94a6;
}

.amount-expense {
  color: #d46a6a;
}

.amount-income {
  color: #2f9e74;
}

.primary-btn {
  margin-top: 20rpx;
  background: #4f7cff;
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
}

.secondary-btn {
  margin-top: 16rpx;
  background: #eef4ff;
  color: #4f7cff;
  border: none;
  border-radius: 16rpx;
}

.danger-btn {
  margin-top: 16rpx;
  background: #fdf0f0;
  color: #d46a6a;
  border: none;
  border-radius: 16rpx;
}

.placeholder {
  padding: 60rpx 0;
  text-align: center;
  color: #8a94a6;
}

.category-display {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.category-display-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  display: block;
}

.category-display-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
