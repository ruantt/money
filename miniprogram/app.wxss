page {
  background: #f5f6f8;
  color: #1f2d3d;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.muted {
  color: #8a94a6;
}

.amount-expense {
  color: #e6513d;
}

.amount-income {
  color: #13a45f;
}

.primary-btn {
  margin-top: 20rpx;
  background: #1a73e8;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
}

.secondary-btn {
  margin-top: 16rpx;
  background: #eef3ff;
  color: #1a73e8;
  border: none;
  border-radius: 12rpx;
}

.danger-btn {
  margin-top: 16rpx;
  background: #ffeceb;
  color: #c43d31;
  border: none;
  border-radius: 12rpx;
}

.placeholder {
  padding: 60rpx 0;
  text-align: center;
  color: #8a94a6;
}

.category-display {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.category-display-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  display: block;
}

.category-display-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
