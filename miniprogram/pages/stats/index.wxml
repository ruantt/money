<view class="page">
  <view wx:if="{{loading}}" class="card placeholder">
    统计加载中...
  </view>

  <view wx:elif="{{loadError}}" class="card placeholder error-card">
    {{loadError}}
  </view>

  <block wx:else>
    <view class="card stats-hero-card">
      <view class="section-title">统计概览</view>

      <view class="filter-row">
        <view
          class="filter-chip {{filterMode === 'all' ? 'filter-chip-active' : ''}}"
          data-mode="all"
          bindtap="onFilterModeTap"
        >
          全部时间
        </view>
        <view
          class="filter-chip {{filterMode === 'currentMonth' ? 'filter-chip-active' : ''}}"
          data-mode="currentMonth"
          bindtap="onFilterModeTap"
        >
          本月
        </view>
        <view
          class="filter-chip {{filterMode === 'customMonth' ? 'filter-chip-active' : ''}}"
          data-mode="customMonth"
          bindtap="onFilterModeTap"
        >
          指定月份
        </view>
      </view>

      <picker wx:if="{{filterMode === 'customMonth'}}" mode="date" fields="month" value="{{selectedMonth}}" bindchange="onMonthChange">
        <view class="month-picker">选择月份：{{selectedMonth}}</view>
      </picker>

      <view class="range-text">当前范围：{{rangeLabel}}</view>

      <view class="stats-kpi-grid">
        <view class="stats-kpi">
          <view class="stats-kpi-label">账单数量</view>
          <view class="stats-kpi-value">{{billCount}}</view>
        </view>
        <view class="stats-kpi">
          <view class="stats-kpi-label">总支出</view>
          <view class="stats-kpi-value amount-expense">¥{{totalExpense}}</view>
        </view>
        <view class="stats-kpi">
          <view class="stats-kpi-label">总收入</view>
          <view class="stats-kpi-value amount-income">¥{{totalIncome}}</view>
        </view>
        <view class="stats-kpi">
          <view class="stats-kpi-label">结余</view>
          <view class="stats-kpi-value">¥{{balance}}</view>
        </view>
      </view>
    </view>

    <view class="card chart-card">
      <view class="chart-header">
        <view class="section-title section-title-compact">日支出趋势</view>
        <view class="chart-subtitle">{{trendRangeText}}</view>
      </view>

      <view wx:if="{{hasExpenseTrendData}}" class="chart-shell">
        <ec-canvas id="expenseTrendChart" canvas-id="expense-trend-canvas" ec="{{expenseTrendEc}}" class="chart-canvas trend-chart"></ec-canvas>
      </view>

      <view wx:else class="placeholder chart-empty">
        当前范围内暂无可绘制的支出趋势
      </view>
    </view>

    <view class="card">
      <view class="section-title">支出分类汇总</view>

      <view wx:if="{{!hasBills}}" class="placeholder">
        <image class="stats-empty-image" src="../../assets/empty/no-stats.png" mode="aspectFit"></image>
        当前范围内还没有账单记录
      </view>

      <view wx:elif="{{!hasExpense}}" class="placeholder">
        当前范围内暂无支出记录
      </view>

      <block wx:else>
        <view class="chart-shell donut-shell">
          <ec-canvas id="expenseDonutChart" canvas-id="expense-donut-canvas" ec="{{expenseDonutEc}}" class="chart-canvas donut-chart"></ec-canvas>
        </view>
        <view class="donut-helper">环形图展示当前范围内各分类支出占比</view>

        <block wx:for="{{expenseCategories}}" wx:key="category">
          <view class="row top-item">
            <view class="top-item-category category-display">
              <image class="category-display-icon top-item-icon" src="{{item.categoryIcon}}" mode="aspectFit"></image>
              <view class="category-display-text">{{item.category}}</view>
            </view>
            <view class="top-item-value amount-expense">¥{{item.amount_text}}（{{item.ratio_text}}）</view>
          </view>
        </block>
      </block>
    </view>

    <view wx:if="{{hasIncome}}" class="card">
      <view class="section-title">收入分类汇总</view>
      <block wx:for="{{incomeCategories}}" wx:key="category">
        <view class="row top-item">
          <view class="top-item-category category-display">
            <image class="category-display-icon top-item-icon" src="{{item.categoryIcon}}" mode="aspectFit"></image>
            <view class="category-display-text">{{item.category}}</view>
          </view>
          <view class="top-item-value amount-income">¥{{item.amount_text}}（{{item.ratio_text}}）</view>
        </view>
      </block>
    </view>
  </block>
</view>
