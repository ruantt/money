<view class="page">
  <view wx:if="{{loading}}" class="card placeholder">
    统计加载中...
  </view>

  <view wx:elif="{{loadError}}" class="card placeholder error-card">
    {{loadError}}
  </view>

  <block wx:else>
    <view class="card">
      <view class="section-title">统计概览</view>

      <view class="filter-row">
        <view
          class="filter-chip {{filterMode === 'all' ? 'filter-chip-active' : ''}}"
          data-mode="all"
          bindtap="onFilterModeTap"
        >
          全部时间
        </view>
        <view
          class="filter-chip {{filterMode === 'currentMonth' ? 'filter-chip-active' : ''}}"
          data-mode="currentMonth"
          bindtap="onFilterModeTap"
        >
          本月
        </view>
        <view
          class="filter-chip {{filterMode === 'customMonth' ? 'filter-chip-active' : ''}}"
          data-mode="customMonth"
          bindtap="onFilterModeTap"
        >
          指定月份
        </view>
      </view>

      <picker wx:if="{{filterMode === 'customMonth'}}" mode="date" fields="month" value="{{selectedMonth}}" bindchange="onMonthChange">
        <view class="month-picker">选择月份：{{selectedMonth}}</view>
      </picker>

      <view class="range-text">当前范围：{{rangeLabel}}</view>

      <view class="row stat-line">
        <view class="muted">账单数量</view>
        <view>{{billCount}}</view>
      </view>
      <view class="row stat-line">
        <view class="muted">总支出</view>
        <view class="amount-expense">¥{{totalExpense}}</view>
      </view>
      <view class="row stat-line">
        <view class="muted">总收入</view>
        <view class="amount-income">¥{{totalIncome}}</view>
      </view>
      <view class="row stat-line">
        <view class="muted">结余</view>
        <view>¥{{balance}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">支出分类汇总</view>

      <view wx:if="{{!hasBills}}" class="placeholder">
        <image class="stats-empty-image" src="../../assets/empty/no-stats.png" mode="aspectFit"></image>
        当前范围内还没有账单记录
      </view>

      <view wx:elif="{{!hasExpense}}" class="placeholder">
        当前范围内暂无支出记录
      </view>

        <block wx:else>
          <block wx:for="{{expenseCategories}}" wx:key="category">
            <view class="row top-item">
              <view class="top-item-category category-display">
                <image class="category-display-icon top-item-icon" src="{{item.categoryIcon}}" mode="aspectFit"></image>
                <view class="category-display-text">{{item.category}}</view>
              </view>
              <view class="top-item-value">¥{{item.amount_text}}（{{item.ratio_text}}）</view>
            </view>
          </block>
        </block>
    </view>

    <view wx:if="{{hasIncome}}" class="card">
      <view class="section-title">收入分类汇总</view>
      <block wx:for="{{incomeCategories}}" wx:key="category">
        <view class="row top-item">
          <view class="top-item-category category-display">
            <image class="category-display-icon top-item-icon" src="{{item.categoryIcon}}" mode="aspectFit"></image>
            <view class="category-display-text">{{item.category}}</view>
          </view>
          <view class="top-item-value">¥{{item.amount_text}}（{{item.ratio_text}}）</view>
        </view>
      </block>
    </view>
  </block>
</view>
