.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.filter-chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 24rpx;
}

.filter-chip-active {
  background: #1d4ed8;
  color: #ffffff;
}

.month-picker {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #334155;
}

.range-text {
  margin-top: 16rpx;
  color: #64748b;
  font-size: 24rpx;
}

.stat-line {
  padding: 8rpx 0;
}

.top-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf0f5;
  gap: 20rpx;
}

.top-item:last-child {
  border-bottom: none;
}

.top-item-category {
  flex: 1;
  min-width: 0;
  color: #1f2d3d;
  font-weight: 500;
}

.top-item-icon {
  width: 32rpx;
  height: 32rpx;
}

.top-item-value {
  flex-shrink: 0;
  color: #334155;
}

.stats-empty-image {
  width: 240rpx;
  height: 160rpx;
  margin: 0 auto 16rpx;
  display: block;
}

.error-card {
  color: #c43d31;
}
