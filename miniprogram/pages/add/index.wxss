.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.section-title-no-margin {
  margin-bottom: 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.compact-row {
  margin-top: 16rpx;
}

.action-btn {
  width: calc((100% - 16rpx) / 2);
  margin-top: 0;
}

.cloud-result {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 24rpx;
  line-height: 1.6;
}

.cloud-result-error {
  background: #ffeceb;
  color: #c43d31;
}

.flow-tip {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.7;
}

.flow-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.flow-message {
  color: #1f2d3d;
  font-weight: 500;
  line-height: 1.6;
}

.flow-step-list {
  margin-top: 20rpx;
}

.flow-step-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.flow-step-row:last-child {
  margin-bottom: 0;
}

.flow-step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #cbd5e1;
  flex-shrink: 0;
}

.flow-step-dot-done {
  background: #16a34a;
}

.flow-step-dot-active {
  background: #1a73e8;
  box-shadow: 0 0 0 8rpx rgba(26, 115, 232, 0.16);
}

.flow-step-dot-error {
  background: #c43d31;
}

.flow-step-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.flow-step-label-done {
  color: #0f766e;
}

.flow-step-label-active {
  color: #1d4ed8;
  font-weight: 600;
}

.flow-step-label-error {
  color: #c43d31;
  font-weight: 600;
}

.result-panel {
  margin-top: 8rpx;
}

.result-title {
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 600;
}

.draft-list {
  margin-top: 20rpx;
}

.draft-card {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.draft-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.draft-index {
  color: #64748b;
  font-size: 24rpx;
}

.draft-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.draft-meta {
  margin-top: 10rpx;
  color: #334155;
}

.draft-meta-category {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.draft-category-icon {
  width: 28rpx;
  height: 28rpx;
}

.empty-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  color: #5b6578;
  margin-bottom: 10rpx;
}

.input {
  background: #f6f8fb;
  border-radius: 10rpx;
  height: 72rpx;
  padding: 0 20rpx;
}

.type-group {
  display: flex;
  gap: 30rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: #1f2d3d;
  font-weight: 500;
}

.picker-category-icon {
  width: 28rpx;
  height: 28rpx;
}
