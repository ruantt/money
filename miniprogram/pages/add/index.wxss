.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  width: calc((100% - 16rpx) / 2);
  margin-top: 0;
}

.path-block {
  margin-top: 20rpx;
}

.path-text {
  margin-top: 10rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f6f8fc;
  color: #334155;
  word-break: break-all;
  white-space: pre-wrap;
  font-size: 24rpx;
  line-height: 1.6;
}

.cloud-result {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 24rpx;
  line-height: 1.6;
}

.cloud-result-error {
  background: #ffeceb;
  color: #c43d31;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  color: #5b6578;
  margin-bottom: 10rpx;
}

.input {
  background: #f6f8fb;
  border-radius: 10rpx;
  height: 72rpx;
  padding: 0 20rpx;
}

.type-group {
  display: flex;
  gap: 30rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-value {
  color: #1f2d3d;
  font-weight: 500;
}

.top-gap {
  margin-top: 24rpx;
}
