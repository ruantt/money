<view class="page">
  <view class="card">
    <view class="section-title">语音记一笔</view>
    <view class="info-row">
      <view class="muted">录音状态</view>
      <view>{{recordStatusText}}</view>
    </view>
    <view class="info-row">
      <view class="muted">录音时长</view>
      <view>{{recordSeconds}} 秒</view>
    </view>
    <view class="info-row">
      <view class="muted">播放状态</view>
      <view>{{playStatusText}}</view>
    </view>
    <view wx:if="{{pauseResumeTip}}" class="muted">{{pauseResumeTip}}</view>

    <view class="button-row">
      <button class="primary-btn action-btn" disabled="{{recordStatus === 'recording' || recordStatus === 'paused' || voiceFlowBusy || confirmSaving || parseDrafts.length > 0}}" bindtap="onStartRecordTap">开始录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'recording'}}" bindtap="onPauseRecordTap">暂停录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'paused'}}" bindtap="onResumeRecordTap">继续录音</button>
      <button class="danger-btn action-btn" disabled="{{recordStatus !== 'recording' && recordStatus !== 'paused'}}" bindtap="onStopRecordTap">停止录音</button>
    </view>

    <view class="path-block">
      <view class="muted">tempFilePath</view>
      <view class="path-text">{{tempFilePath || "暂无录音文件"}}</view>
    </view>

    <view class="button-row">
      <button class="secondary-btn action-btn" disabled="{{!tempFilePath || playStatus === 'playing' || voiceFlowBusy}}" bindtap="onPlayRecordTap">播放录音</button>
      <button class="danger-btn action-btn" disabled="{{playStatus !== 'playing'}}" bindtap="onStopPlayTap">停止播放</button>
    </view>

    <view wx:if="{{recordError}}" class="cloud-result cloud-result-error">{{recordError}}</view>
    <view wx:if="{{playError}}" class="cloud-result cloud-result-error">{{playError}}</view>
  </view>

  <view class="card">
    <view class="section-title">语音处理进度</view>
    <view class="flow-tip">停止录音后，系统会自动上传录音、识别语音并生成账单草稿。</view>

    <view class="flow-panel">
      <view class="flow-message">{{voiceFlowMessage}}</view>
      <view class="flow-step-list">
        <block wx:for="{{voiceFlowSteps}}" wx:key="key">
          <view class="flow-step-row">
            <view class="flow-step-dot flow-step-dot-{{item.status}}"></view>
            <view class="flow-step-label flow-step-label-{{item.status}}">{{item.label}}</view>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{voiceFlowError}}" class="cloud-result cloud-result-error">{{voiceFlowError}}</view>

    <button wx:if="{{voiceFlowStage === 'error' && tempFilePath && !voiceFlowBusy}}" class="primary-btn" bindtap="onRetryAutoFlowTap">重试自动处理</button>

    <view class="fallback-title">备用处理入口</view>
    <view class="muted">如果自动流程失败，可以使用下面的按钮继续处理当前录音。</view>

    <view class="info-row">
      <view class="muted">上传状态</view>
      <view>{{uploadStatusText}}</view>
    </view>
    <button class="secondary-btn" loading="{{uploadStatus === 'uploading'}}" disabled="{{!tempFilePath || uploadStatus === 'uploading' || voiceFlowBusy || parseDrafts.length > 0 || confirmSaving}}" bindtap="onUploadRecordTap">上传录音</button>

    <view class="path-block">
      <view class="muted">fileID</view>
      <view class="path-text">{{uploadFileID || "上传成功后会显示 fileID"}}</view>
    </view>

    <view class="info-row top-gap">
      <view class="muted">处理状态</view>
      <view>{{processStatusText}}</view>
    </view>
    <button class="secondary-btn" loading="{{processStatus === 'processing'}}" disabled="{{!uploadFileID || processStatus === 'processing' || voiceFlowBusy || parseDrafts.length > 0 || confirmSaving}}" bindtap="onSubmitProcessTap">提交云端处理</button>

    <view class="path-block">
      <view class="muted">transcript</view>
      <view class="path-text">{{processTranscript || "提交成功后会显示 transcript"}}</view>
    </view>

    <view class="path-block">
      <view class="muted">处理结果</view>
      <view class="path-text">{{processResult || "提交成功后会显示完整处理结果"}}</view>
    </view>

    <view wx:if="{{uploadError}}" class="cloud-result cloud-result-error">{{uploadError}}</view>
    <view wx:if="{{processError}}" class="cloud-result cloud-result-error">{{processError}}</view>
  </view>

  <view class="card">
    <view class="section-title">AI 草稿确认</view>
    <view class="info-row">
      <view class="muted">解析状态</view>
      <view>{{parseStatusText}}</view>
    </view>
    <button class="secondary-btn" loading="{{parseStatus === 'processing'}}" disabled="{{!processTranscript || parseStatus === 'processing' || voiceFlowBusy || parseDrafts.length > 0 || confirmSaving}}" bindtap="onParseBillDraftTap">手动触发 AI 解析</button>

    <view class="path-block">
      <view class="muted">解析提示</view>
      <view class="path-text">{{parseMessage || "自动处理完成后会在这里生成结构化草稿；如果自动流程失败，也可以手动重试。"}}</view>
    </view>

    <view id="voice-draft-result" class="result-panel">
      <view class="result-title">AI 解析结果展示区</view>

      <view wx:if="{{parseDrafts.length > 0}}" class="draft-list">
        <block wx:for="{{parseDrafts}}" wx:key="index">
          <view class="draft-card">
            <view class="draft-header">
              <view class="draft-index">第 {{index + 1}} 笔</view>
              <view class="draft-amount">¥{{item.amount}}</view>
            </view>
            <view class="draft-meta">分类：{{item.category}}</view>
            <view class="draft-meta">备注：{{item.note || "无"}}</view>
          </view>
        </block>
      </view>

      <view wx:elif="{{parseStatus === 'processing'}}" class="empty-tip">
        AI 正在解析，结果稍后会显示在这里。
      </view>

      <view wx:else class="empty-tip">
        暂无可展示的账单草稿，完成解析后会在这里显示。
      </view>
    </view>

    <view wx:if="{{parseMissingFields.length > 0}}" class="path-block">
      <view class="muted">缺失字段</view>
      <view class="path-text">{{parseMissingFieldsText}}</view>
    </view>

    <view wx:if="{{parseDrafts.length > 0}}" class="button-row">
      <button class="primary-btn action-btn" loading="{{confirmSaving}}" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onConfirmDraftTap">确认保存</button>
      <button class="secondary-btn action-btn" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onCancelDraftTap">取消</button>
    </view>

    <view wx:if="{{parseError}}" class="cloud-result cloud-result-error">{{parseError}}</view>
  </view>

  <view class="card">
    <view class="section-title">手动补记</view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">类型</view>
      <radio-group class="type-group" bindchange="onTypeChange">
        <label class="radio-item">
          <radio value="expense" checked="{{type === 'expense'}}" />支出
        </label>
        <label class="radio-item">
          <radio value="income" checked="{{type === 'income'}}" />收入
        </label>
      </radio-group>
    </view>

    <view class="field row">
      <view class="label">类目</view>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value">{{categoryOptions[categoryIndex]}}</view>
      </picker>
    </view>

    <view class="field row">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-value">{{date}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" placeholder="可选" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <button class="primary-btn" bindtap="onSave">保存</button>
    <button class="secondary-btn" bindtap="onFillExample">快速填充示例</button>
  </view>
</view>
