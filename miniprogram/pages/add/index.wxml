<view class="page">
  <view class="card">
    <view class="section-header">
      <image
        wx:if="{{recordStatus === 'recording' || recordStatus === 'paused'}}"
        class="section-icon"
        src="../../assets/icons/mic-recording.png"
        mode="aspectFit"
      ></image>
      <image
        wx:else
        class="section-icon"
        src="../../assets/icons/mic.png"
        mode="aspectFit"
      ></image>
      <view class="section-title section-title-no-margin">语音记一笔</view>
    </view>
    <view class="flow-tip">点开始录音，说完后点停止，系统会自动整理成账单草稿。</view>

    <view class="record-visual-panel">
      <view class="record-ripple-shell {{recordStatus === 'recording' ? 'record-ripple-shell-active' : recordStatus === 'paused' ? 'record-ripple-shell-paused' : ''}}">
        <view class="record-ripple record-ripple-one"></view>
        <view class="record-ripple record-ripple-two"></view>
        <view class="record-ripple record-ripple-three"></view>
        <view class="record-wave {{recordStatus === 'recording' ? 'record-wave-active' : recordStatus === 'paused' ? 'record-wave-paused' : ''}}">
          <view class="record-wave-bar wave-bar-1"></view>
          <view class="record-wave-bar wave-bar-2"></view>
          <view class="record-wave-bar wave-bar-3"></view>
          <view class="record-wave-bar wave-bar-4"></view>
          <view class="record-wave-bar wave-bar-5"></view>
          <view class="record-wave-bar wave-bar-6"></view>
          <view class="record-wave-bar wave-bar-7"></view>
        </view>
      </view>

      <view class="record-visual-meta">
        <view class="record-status-chip record-status-chip-{{recordStatus}}">{{recordStatusText}}</view>
        <view class="record-visual-text">
          {{recordStatus === 'recording' ? '正在捕捉语音波形...' : recordStatus === 'paused' ? '录音已暂停，波形保持当前状态。' : '开始录音后，这里会出现动态反馈。'}}
        </view>
      </view>
    </view>

    <view class="info-row">
      <view class="muted">录音时长</view>
      <view>{{recordSeconds}} 秒</view>
    </view>
    <view wx:if="{{pauseResumeTip}}" class="muted">{{pauseResumeTip}}</view>

    <view class="button-row">
      <button class="primary-btn action-btn" disabled="{{recordStatus === 'recording' || recordStatus === 'paused' || voiceFlowBusy || confirmSaving || parseDrafts.length > 0}}" bindtap="onStartRecordTap">开始录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'recording'}}" bindtap="onPauseRecordTap">暂停录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'paused'}}" bindtap="onResumeRecordTap">继续录音</button>
      <button class="danger-btn action-btn" disabled="{{recordStatus !== 'recording' && recordStatus !== 'paused'}}" bindtap="onStopRecordTap">停止录音</button>
    </view>

    <view wx:if="{{tempFilePath}}" class="button-row compact-row">
      <button class="secondary-btn action-btn" disabled="{{playStatus === 'playing' || voiceFlowBusy}}" bindtap="onPlayRecordTap">播放录音</button>
      <button class="secondary-btn action-btn" disabled="{{playStatus !== 'playing'}}" bindtap="onStopPlayTap">停止播放</button>
    </view>

    <view wx:if="{{recordError}}" class="cloud-result cloud-result-error">{{recordError}}</view>
    <view wx:if="{{playError}}" class="cloud-result cloud-result-error">{{playError}}</view>
  </view>

  <view class="card">
    <view class="section-title">处理进度</view>

    <view class="flow-panel">
      <view class="flow-message">{{voiceFlowMessage}}</view>
      <view class="flow-step-list">
        <block wx:for="{{voiceFlowSteps}}" wx:key="key">
          <view class="flow-step-row">
            <view class="flow-step-dot flow-step-dot-{{item.status}}"></view>
            <view class="flow-step-label flow-step-label-{{item.status}}">{{item.label}}</view>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{voiceFlowError}}" class="cloud-result cloud-result-error">{{voiceFlowError}}</view>

    <view wx:if="{{voiceFlowStage === 'error' && !voiceFlowBusy}}" class="button-row">
      <button wx:if="{{tempFilePath}}" class="primary-btn action-btn" bindtap="onRetryAutoFlowTap">重试处理</button>
      <button class="secondary-btn action-btn" bindtap="onRecordAgainTap">重新录音</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">待确认账单</view>

    <view id="voice-draft-result" class="result-panel">
      <view class="result-title">{{draftEditMode ? '选择要修改的账单' : 'AI 已整理出这些账单草稿'}}</view>
      <view wx:if="{{parseDrafts.length > 0 && draftEditMode}}" class="result-subtitle">
        逐笔修改后返回草稿列表，再统一确认添加。
      </view>

      <view wx:if="{{parseDrafts.length > 0}}" class="draft-list">
        <block wx:for="{{parseDrafts}}" wx:key="index">
          <view class="draft-card {{draftEditMode ? 'draft-card-editing' : ''}}">
            <view class="draft-header">
              <view class="draft-header-main">
                <view class="draft-index">第 {{index + 1}} 笔</view>
                <view class="draft-type-tag draft-type-tag-{{item.type}} {{item.type === 'income' ? 'amount-income' : 'amount-expense'}}">{{item.typeText}}</view>
              </view>
              <view class="draft-amount {{item.type === 'income' ? 'amount-income' : 'amount-expense'}}">
                {{item.type === 'income' ? '+' : '-'}}¥{{item.amount || '--'}}
              </view>
            </view>
            <view class="draft-meta draft-meta-category">
              <view>类目：</view>
              <view class="category-display">
                <image class="category-display-icon draft-category-icon" src="{{item.categoryIcon}}" mode="aspectFit"></image>
                <view class="category-display-text">{{item.category}}</view>
              </view>
            </view>
            <view class="draft-meta">日期：{{item.date}}</view>
            <view class="draft-meta">备注：{{item.note || "无"}}</view>
            <button wx:if="{{draftEditMode}}" class="secondary-btn draft-edit-btn" data-index="{{index}}" bindtap="onEditDraftTap">修改这笔</button>
          </view>
        </block>
      </view>

      <view wx:elif="{{voiceFlowBusy}}" class="empty-tip">
        正在整理这笔账，稍后会自动显示在这里。
      </view>

      <view wx:elif="{{voiceFlowStage === 'error'}}" class="empty-tip">
        这次处理没有完成，你可以重试处理，或重新录一段语音。
      </view>

      <view wx:else class="empty-tip">
        录完音后，系统会自动把结果整理成待确认账单。
      </view>
    </view>

    <view wx:if="{{parseDrafts.length > 0 && !draftEditMode}}" class="button-row">
      <button class="primary-btn action-btn action-btn-third" loading="{{confirmSaving}}" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onConfirmDraftTap">确认添加</button>
      <button class="secondary-btn action-btn action-btn-third" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onModifyDraftTap">修改信息</button>
      <button class="danger-btn action-btn action-btn-third" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onCancelDraftTap">取消本次</button>
    </view>

    <view wx:if="{{parseDrafts.length > 0 && draftEditMode}}" class="button-row">
      <button class="primary-btn action-btn" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onBackToDraftTap">返回草稿</button>
      <button class="danger-btn action-btn" disabled="{{confirmSaving || voiceFlowBusy}}" bindtap="onCancelDraftTap">取消本次</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">手动记一笔</view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">类型</view>
      <radio-group class="type-group" bindchange="onTypeChange">
        <label class="radio-item">
          <radio value="expense" checked="{{type === 'expense'}}" />支出
        </label>
        <label class="radio-item">
          <radio value="income" checked="{{type === 'income'}}" />收入
        </label>
      </radio-group>
    </view>

    <view class="field row">
      <view class="label">类目</view>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value category-display">
          <image class="category-display-icon picker-category-icon" src="{{selectedCategoryIcon}}" mode="aspectFit"></image>
          <view class="category-display-text">{{selectedCategoryText}}</view>
        </view>
      </picker>
    </view>

    <view class="field row">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-value">{{date}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" placeholder="可选" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <button class="primary-btn" bindtap="onSave">保存</button>
    <button class="secondary-btn" bindtap="onFillExample">快速填充示例</button>
  </view>
</view>
