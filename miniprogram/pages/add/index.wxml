<view class="page">
  <view class="card">
    <view class="section-title">语音记一笔</view>
    <view class="info-row">
      <view class="muted">录音状态</view>
      <view>{{recordStatusText}}</view>
    </view>
    <view class="info-row">
      <view class="muted">录音时长</view>
      <view>{{recordSeconds}} 秒</view>
    </view>
    <view class="info-row">
      <view class="muted">播放状态</view>
      <view>{{playStatusText}}</view>
    </view>
    <view wx:if="{{pauseResumeTip}}" class="muted">{{pauseResumeTip}}</view>
    <view class="button-row">
      <button class="primary-btn action-btn" disabled="{{recordStatus === 'recording' || recordStatus === 'paused'}}" bindtap="onStartRecordTap">开始录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'recording'}}" bindtap="onPauseRecordTap">暂停录音</button>
      <button class="secondary-btn action-btn" disabled="{{!supportsPauseResume || recordStatus !== 'paused'}}" bindtap="onResumeRecordTap">继续录音</button>
      <button class="danger-btn action-btn" disabled="{{recordStatus !== 'recording' && recordStatus !== 'paused'}}" bindtap="onStopRecordTap">停止录音</button>
    </view>

    <view class="path-block">
      <view class="muted">tempFilePath</view>
      <view class="path-text">{{tempFilePath || "暂无录音文件"}}</view>
    </view>

    <view class="button-row">
      <button class="secondary-btn action-btn" disabled="{{!tempFilePath || playStatus === 'playing'}}" bindtap="onPlayRecordTap">播放录音</button>
      <button class="danger-btn action-btn" disabled="{{playStatus !== 'playing'}}" bindtap="onStopPlayTap">停止播放</button>
    </view>

    <view wx:if="{{recordError}}" class="cloud-result cloud-result-error">{{recordError}}</view>
    <view wx:if="{{playError}}" class="cloud-result cloud-result-error">{{playError}}</view>
  </view>

  <view class="card">
    <view class="section-title">上传与云端处理</view>
    <view class="info-row">
      <view class="muted">上传状态</view>
      <view>{{uploadStatusText}}</view>
    </view>
    <button class="primary-btn" loading="{{uploadStatus === 'uploading'}}" disabled="{{!tempFilePath || uploadStatus === 'uploading'}}" bindtap="onUploadRecordTap">上传录音</button>

    <view class="path-block">
      <view class="muted">fileID</view>
      <view class="path-text">{{uploadFileID || "上传成功后会显示 fileID"}}</view>
    </view>

    <view class="info-row top-gap">
      <view class="muted">处理状态</view>
      <view>{{processStatusText}}</view>
    </view>
    <button class="primary-btn" loading="{{processStatus === 'processing'}}" disabled="{{!uploadFileID || processStatus === 'processing'}}" bindtap="onSubmitProcessTap">提交云端处理</button>

    <view class="path-block">
      <view class="muted">处理结果</view>
      <view class="path-text">{{processResult || "提交成功后会显示 transcript 和处理结果"}}</view>
    </view>

    <view wx:if="{{uploadError}}" class="cloud-result cloud-result-error">{{uploadError}}</view>
    <view wx:if="{{processError}}" class="cloud-result cloud-result-error">{{processError}}</view>
  </view>

  <view class="card">
    <view class="section-title">手动补记</view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">类型</view>
      <radio-group class="type-group" bindchange="onTypeChange">
        <label class="radio-item">
          <radio value="expense" checked="{{type === 'expense'}}" />支出
        </label>
        <label class="radio-item">
          <radio value="income" checked="{{type === 'income'}}" />收入
        </label>
      </radio-group>
    </view>

    <view class="field row">
      <view class="label">类目</view>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value">{{categoryOptions[categoryIndex]}}</view>
      </picker>
    </view>

    <view class="field row">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-value">{{date}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" placeholder="可选" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <button class="primary-btn" bindtap="onSave">保存</button>
    <button class="secondary-btn" bindtap="onFillExample">快速填充示例</button>
  </view>
</view>
