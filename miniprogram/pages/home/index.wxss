.month-hero {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.month-hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.month-caption {
  color: #8a94a6;
  font-size: 24rpx;
}

.month-picker-trigger {
  margin-top: 8rpx;
}

.month-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.month-picker-text {
  margin-top: 8rpx;
  color: #1a73e8;
  font-size: 24rpx;
}

.month-reset {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #1a73e8;
  font-size: 24rpx;
  flex-shrink: 0;
}

.month-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.month-summary-item {
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
}

.month-summary-label {
  color: #8a94a6;
  font-size: 22rpx;
}

.month-summary-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.day-card {
  padding-top: 20rpx;
  padding-bottom: 12rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.day-title {
  font-size: 30rpx;
  font-weight: 600;
}

.day-subtitle {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.day-totals {
  text-align: right;
  flex-shrink: 0;
}

.day-total-expense,
.day-total-income {
  font-size: 22rpx;
  line-height: 1.6;
}

.day-total-expense {
  color: #e6513d;
}

.day-total-income {
  color: #13a45f;
}

.day-list {
  margin-top: 8rpx;
}

.bill-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.bill-main {
  flex: 1;
  min-width: 0;
}

.bill-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bill-category {
  min-width: 0;
  color: #1f2d3d;
  font-weight: 600;
}

.bill-category-icon {
  width: 26rpx;
  height: 26rpx;
}

.bill-type {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
}

.bill-note {
  margin-top: 8rpx;
  color: #334155;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bill-meta {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.bill-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.bill-amount {
  font-size: 30rpx;
  font-weight: 700;
}

.bill-more {
  color: #1a73e8;
  font-size: 22rpx;
}

.empty-card {
  text-align: center;
}

.empty-image {
  width: 240rpx;
  height: 160rpx;
  margin: 0 auto 12rpx;
  display: block;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-text {
  margin-top: 16rpx;
}

.empty-action {
  margin-top: 24rpx;
}

.load-more-card {
  text-align: center;
}

.error-card {
  color: #c43d31;
}
