.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.summary-item {
  flex: 1;
}

.bill-card {
  margin-bottom: 18rpx;
}

.amount {
  font-size: 40rpx;
  font-weight: 700;
}

.bill-meta {
  margin-top: 10rpx;
  color: #334155;
}

.bill-footer {
  margin-top: 16rpx;
}

.type-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.income-tag {
  background: #e7f7ee;
  color: #0e8a4b;
}

.expense-tag {
  background: #feecea;
  color: #c43d31;
}

.delete-btn {
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background: #ffeceb;
  color: #c43d31;
  border: none;
  border-radius: 10rpx;
  padding: 0;
  margin: 0;
}
