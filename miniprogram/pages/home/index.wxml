<view class="page">
  <view class="card month-hero">
    <view class="month-hero-top">
      <view>
        <view class="month-caption">当前查看</view>
        <picker mode="date" fields="month" value="{{selectedMonth}}" bindchange="onMonthChange">
          <view class="month-picker-trigger">
            <view class="month-title">{{selectedMonthLabel}}</view>
            <view class="month-picker-text">切换月份</view>
          </view>
        </picker>
      </view>
      <view wx:if="{{selectedMonth !== currentMonth}}" class="month-reset" bindtap="onResetMonthTap">回到本月</view>
    </view>

    <view class="month-summary-grid">
      <view class="month-summary-item">
        <view class="month-summary-label">账单数</view>
        <view class="month-summary-value">{{monthSummary.billCount}}</view>
      </view>
      <view class="month-summary-item">
        <view class="month-summary-label">总支出</view>
        <view class="month-summary-value amount-expense">¥{{monthSummary.totalExpense}}</view>
      </view>
      <view class="month-summary-item">
        <view class="month-summary-label">总收入</view>
        <view class="month-summary-value amount-income">¥{{monthSummary.totalIncome}}</view>
      </view>
      <view class="month-summary-item">
        <view class="month-summary-label">结余</view>
        <view class="month-summary-value {{monthSummary.balanceClass}}">¥{{monthSummary.balance}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card placeholder">
    账单加载中...
  </view>

  <view wx:elif="{{loadError}}" class="card placeholder error-card">
    {{loadError}}
  </view>

  <view wx:elif="{{dateGroups.length === 0}}" class="card empty-card">
    <image class="empty-image" src="../../assets/empty/no-bills.png" mode="aspectFit"></image>
    <view class="empty-title">{{selectedMonthLabel}} 还没有账单</view>
    <view class="muted empty-text">先去记一笔，回来就能按日期查看这个月的账本。</view>
    <button class="primary-btn empty-action" bindtap="onGoAddTap">去记一笔</button>
  </view>

  <block wx:else>
    <block wx:for="{{dateGroups}}" wx:key="dateKey" wx:for-item="group">
      <view class="card day-card">
        <view class="day-header">
          <view>
            <view class="day-title">{{group.dateLabel}}</view>
            <view class="day-subtitle">{{group.billCount}} 笔</view>
          </view>
          <view class="day-totals">
            <view wx:if="{{group.expenseTotalText !== '0.00'}}" class="day-total-expense">支出 ¥{{group.expenseTotalText}}</view>
            <view wx:if="{{group.incomeTotalText !== '0.00'}}" class="day-total-income">收入 ¥{{group.incomeTotalText}}</view>
          </view>
        </view>

        <view class="day-list">
          <block wx:for="{{group.items}}" wx:key="id" wx:for-item="bill">
            <view class="bill-row" data-id="{{bill.id}}" bindlongpress="onBillLongPress">
              <view class="bill-main">
                <view class="bill-title-row">
                  <view class="bill-category category-display">
                    <image class="category-display-icon bill-category-icon" src="{{bill.category_icon}}" mode="aspectFit"></image>
                    <view class="category-display-text">{{bill.category_text}}</view>
                  </view>
                  <view class="bill-type">{{bill.type_text}}</view>
                </view>
                <view wx:if="{{bill.showNote}}" class="bill-note">{{bill.note_text}}</view>
                <view class="bill-meta">{{bill.metaText}}</view>
              </view>

              <view class="bill-side">
                <view class="bill-amount {{bill.amount_class}}">{{bill.amount_prefix}}¥{{bill.amount_text}}</view>
                <view class="bill-more" data-id="{{bill.id}}" bindtap="onBillActionTap">更多</view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>

    <view wx:if="{{loadingMore}}" class="card placeholder load-more-card">
      正在加载更多...
    </view>

    <view wx:elif="{{!hasMore}}" class="card placeholder load-more-card">
      这个月的账单已经看完了
    </view>
  </block>
</view>
