<view class="page">
  <view class="card">
    <view class="section-title">阶段A：本地存储模式</view>
    <view class="muted">当前数据存储 key：{{storageKey}}</view>

    <button class="secondary-btn" bindtap="onExportData">导出数据（复制JSON到剪贴板）</button>
    <button class="danger-btn" bindtap="onClearData">清空所有数据</button>
  </view>
</view>
